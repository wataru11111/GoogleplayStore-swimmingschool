<!-- app/views/admin/settings/index.html.erb -->
<h2>登録可能年月日設定</h2>

<%= form_with url: admin_area_setting_path('1'), method: :put do %>
  <div>
    <label>お休み登録可能最終日 (例: 2025-06-27):</label>
    <%= text_field_tag :available_off_day, @available_off_day %>
  </div>

  <div>
    <label>振替登録可能最終日 (例: 2025-06-27):</label>
    <%= text_field_tag :available_transfer_day, @available_transfer_day %>
  </div>

  <hr>

  <h3>お休み登録不可能日の設定</h3>
  
  <!-- お休み不可能日 変更完了メッセージ -->
  <div id="success_message_off" style="display: none; padding: 10px; margin-bottom: 15px; background: #d4edda; color: #155724; border: 1px solid #c3e6cb; border-radius: 5px;">
    ✓ 変更完了
  </div>
  
  <div class="disabled-off-manager">
    <div class="add-disabled-section" style="margin-bottom: 20px; padding: 15px; border: 1px solid #ddd; border-radius: 5px;">
      <h4>新規追加</h4>
      <div style="margin-bottom: 10px;">
        <label>日付を選択:</label><br>
        <input type="date" id="select_date_off" style="padding: 5px; font-size: 14px;">
      </div>
      
      <div style="margin-bottom: 10px;">
        <button type="button" id="add_all_day_off" class="btn btn-warning" style="margin-right: 10px;">全休として追加</button>
        <button type="button" id="show_time_input_off" class="btn btn-info">時間指定で追加</button>
      </div>
      
      <div id="time_input_section_off" style="display: none; margin-top: 10px; padding: 10px; background: #fff3cd; border: 2px solid #ffc107; border-radius: 5px;">
        <p style="margin: 0 0 10px 0; font-weight: bold; color: #856404;">⏰ 時間を選択してください</p>
        <div style="margin-bottom: 10px;">
          <label style="font-weight: bold;">開始時間:</label><br>
          <select id="start_time_off" style="padding: 5px; font-size: 14px; margin-bottom: 10px;">
            <option value="09:00">09:00</option>
            <option value="10:00">10:00</option>
            <option value="11:00" selected>11:00</option>
            <option value="12:00">12:00</option>
            <option value="13:00">13:00</option>
            <option value="14:00">14:00</option>
            <option value="15:00">15:00</option>
            <option value="16:00">16:00</option>
            <option value="17:00">17:00</option>
            <option value="18:00">18:00</option>
            <option value="19:00">19:00</option>
            <option value="20:00">20:00</option>
          </select>
        </div>
        <div style="margin-bottom: 10px;">
          <label style="font-weight: bold;">終了時間:</label><br>
          <select id="end_time_off" style="padding: 5px; font-size: 14px; margin-bottom: 10px;">
            <option value="09:00">09:00</option>
            <option value="10:00">10:00</option>
            <option value="11:00">11:00</option>
            <option value="12:00">12:00</option>
            <option value="13:00">13:00</option>
            <option value="14:00">14:00</option>
            <option value="15:00">15:00</option>
            <option value="16:00" selected>16:00</option>
            <option value="17:00">17:00</option>
            <option value="18:00">18:00</option>
            <option value="19:00">19:00</option>
            <option value="20:00">20:00</option>
            <option value="21:00">21:00</option>
          </select>
        </div>
        <button type="button" id="add_time_range_off" class="btn btn-success" style="width: 100%;">この時間帯を追加</button>
      </div>
    </div>

    <div class="disabled-list-section">
      <h4>登録済み不可能日時</h4>
      <div id="disabled_items_list_off" style="margin-top: 10px;">
        <!-- JavaScriptで動的に追加 -->
      </div>
    </div>
    
  </div>

  <hr>

  <h3>振替登録不可能日の設定</h3>
  
  <!-- 変更完了メッセージ -->
  <div id="success_message" style="display: none; padding: 10px; margin-bottom: 15px; background: #d4edda; color: #155724; border: 1px solid #c3e6cb; border-radius: 5px;">
    ✓ 変更完了
  </div>
  
  <div class="disabled-transfer-manager">
    <div class="add-disabled-section" style="margin-bottom: 20px; padding: 15px; border: 1px solid #ddd; border-radius: 5px;">
      <h4>新規追加</h4>
      <div style="margin-bottom: 10px;">
        <label>日付を選択:</label><br>
        <input type="date" id="select_date" style="padding: 5px; font-size: 14px;">
      </div>
      
      <div style="margin-bottom: 10px;">
        <button type="button" id="add_all_day" class="btn btn-warning" style="margin-right: 10px;">全休として追加</button>
        <button type="button" id="show_time_input" class="btn btn-info">時間指定で追加</button>
      </div>
      
      <div id="time_input_section" style="display: none; margin-top: 10px; padding: 10px; background: #fff3cd; border: 2px solid #ffc107; border-radius: 5px;">
        <p style="margin: 0 0 10px 0; font-weight: bold; color: #856404;">⏰ 時間を選択してください</p>
        <div style="margin-bottom: 10px;">
          <label style="font-weight: bold;">開始時間:</label><br>
          <select id="start_time" style="padding: 5px; font-size: 14px; margin-bottom: 10px;">
            <option value="09:00">09:00</option>
            <option value="10:00">10:00</option>
            <option value="11:00" selected>11:00</option>
            <option value="12:00">12:00</option>
            <option value="13:00">13:00</option>
            <option value="14:00">14:00</option>
            <option value="15:00">15:00</option>
            <option value="16:00">16:00</option>
            <option value="17:00">17:00</option>
            <option value="18:00">18:00</option>
            <option value="19:00">19:00</option>
            <option value="20:00">20:00</option>
          </select>
        </div>
        <div style="margin-bottom: 10px;">
          <label style="font-weight: bold;">終了時間:</label><br>
          <select id="end_time" style="padding: 5px; font-size: 14px; margin-bottom: 10px;">
            <option value="09:00">09:00</option>
            <option value="10:00">10:00</option>
            <option value="11:00">11:00</option>
            <option value="12:00">12:00</option>
            <option value="13:00">13:00</option>
            <option value="14:00">14:00</option>
            <option value="15:00">15:00</option>
            <option value="16:00" selected>16:00</option>
            <option value="17:00">17:00</option>
            <option value="18:00">18:00</option>
            <option value="19:00">19:00</option>
            <option value="20:00">20:00</option>
            <option value="21:00">21:00</option>
          </select>
        </div>
        <button type="button" id="add_time_range" class="btn btn-success" style="width: 100%;">この時間帯を追加</button>
      </div>
    </div>

    <div class="disabled-list-section">
      <h4>登録済み不可能日時</h4>
      <div id="disabled_items_list" style="margin-top: 10px;">
        <!-- JavaScriptで動的に追加 -->
      </div>
    </div>
    
  </div>

  <%= submit_tag "基本設定を保存", class: "btn btn-primary", style: "margin-top: 20px;" %>
<% end %>

<script>
document.addEventListener('turbo:load', function() {
  let disabledSlots = [];
  
  // 既存データを読み込む（@disabled_transfer_slotsは既にJSON文字列）
  try {
    const existingData = <%= raw(@disabled_transfer_slots.presence || '[]') %>;
    console.log('Raw existing data:', existingData);
    console.log('Type:', typeof existingData);
    
    // existingDataは既にJavaScriptの配列/オブジェクトとして展開されている
    if (Array.isArray(existingData)) {
      disabledSlots = existingData;
      console.log('Loaded disabled slots:', disabledSlots);
    }
  } catch(e) {
    console.error('Failed to load existing data:', e);
    disabledSlots = [];
  }
  
  renderList();
  
  // 時間指定セクションの表示/非表示
  document.getElementById('show_time_input').addEventListener('click', function() {
    const section = document.getElementById('time_input_section');
    section.style.display = section.style.display === 'none' ? 'block' : 'none';
  });
  
  // 全休として追加
  document.getElementById('add_all_day').addEventListener('click', function() {
    const dateInput = document.getElementById('select_date');
    if (!dateInput.value) {
      alert('日付を選択してください');
      return;
    }
    
    // Ajaxで即座に保存
    fetch('/admin_area/settings/add_slot', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({
        date: dateInput.value,
        slot_type: 'all_day'
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        disabledSlots = data.slots;
        renderList();
        dateInput.value = '';
        showSuccessMessage();
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('保存に失敗しました');
    });
  });
  
  // 時間指定で追加
  document.getElementById('add_time_range').addEventListener('click', function() {
    const dateInput = document.getElementById('select_date');
    const startTime = document.getElementById('start_time').value;
    const endTime = document.getElementById('end_time').value;
    
    if (!dateInput.value) {
      alert('日付を選択してください');
      return;
    }
    
    if (!startTime || !endTime) {
      alert('開始時間と終了時間を入力してください');
      return;
    }
    
    if (startTime >= endTime) {
      alert('終了時間は開始時間より後にしてください');
      return;
    }
    
    // Ajaxで即座に保存
    fetch('/admin_area/settings/add_slot', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({
        date: dateInput.value,
        slot_type: 'time_range',
        start_time: startTime,
        end_time: endTime
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        disabledSlots = data.slots;
        renderList();
        dateInput.value = '';
        document.getElementById('time_input_section').style.display = 'none';
        showSuccessMessage();
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('保存に失敗しました');
    });
  });
  
  function showSuccessMessage() {
    const msg = document.getElementById('success_message');
    msg.style.display = 'block';
    setTimeout(function() {
      msg.style.display = 'none';
    }, 3000); // 3秒後に自動的に消える
  }
  
  function renderList() {
    const listContainer = document.getElementById('disabled_items_list');
    
    if (disabledSlots.length === 0) {
      listContainer.innerHTML = '<p class="text-muted">登録されている不可能日時はありません</p>';
      updateHiddenField();
      return;
    }
    
    // 日付順にソート
    disabledSlots.sort((a, b) => {
      if (a.date !== b.date) return a.date.localeCompare(b.date);
      if (a.type === 'all_day') return -1;
      if (b.type === 'all_day') return 1;
      return (a.start_time || '').localeCompare(b.start_time || '');
    });
    
    let html = '<div style="max-height: 400px; overflow-y: auto;">';
    html += '<table class="table table-striped" style="font-size: 14px;">';
    html += '<thead><tr><th>日付</th><th>制限内容</th><th>操作</th></tr></thead>';
    html += '<tbody>';
    
    disabledSlots.forEach((slot, index) => {
      html += '<tr>';
      html += `<td>${slot.date}</td>`;
      
      if (slot.type === 'all_day') {
        html += '<td><span class="badge bg-danger">全休</span></td>';
      } else {
        html += `<td><span class="badge bg-warning text-dark">${slot.start_time} ～ ${slot.end_time}</span></td>`;
      }
      
      html += `<td><button type="button" class="btn btn-sm btn-danger delete-btn" data-index="${index}" data-date="${slot.date}" data-type="${slot.type}" data-start-time="${slot.start_time || ''}" data-end-time="${slot.end_time || ''}">削除</button></td>`;
      html += '</tr>';
    });
    
    html += '</tbody></table></div>';
    listContainer.innerHTML = html;
    
    // 削除ボタンのイベント設定
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const index = parseInt(this.getAttribute('data-index'));
        const date = this.getAttribute('data-date');
        const type = this.getAttribute('data-type');
        const startTime = this.getAttribute('data-start-time');
        const endTime = this.getAttribute('data-end-time');
        if (confirm('この設定を削除しますか？')) {
          // Ajaxで削除
          fetch('/admin_area/settings/delete_slot', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
            },
            body: JSON.stringify({
              index: index,
              date: date,
              type: type,
              start_time: startTime,
              end_time: endTime
            })
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              disabledSlots = data.slots;
              renderList();
            }
          })
          .catch(error => {
            console.error('Error:', error);
            alert('削除に失敗しました');
          });
        }
      });
    });
    
    updateHiddenField();
  }
  
  function updateHiddenField() {
    // 不要になったが互換性のため残す
  }

  // ========== お休み不可能日の管理 ==========
  let disabledOffSlots = [];
  
  // 既存データを読み込む（@disabled_off_slotsは既にJSON文字列）
  try {
    const existingOffData = <%= raw(@disabled_off_slots.presence || '[]') %>;
    console.log('Raw existing off data:', existingOffData);
    
    if (Array.isArray(existingOffData)) {
      disabledOffSlots = existingOffData;
      console.log('Loaded disabled off slots:', disabledOffSlots);
    }
  } catch(e) {
    console.error('Failed to load existing off data:', e);
    disabledOffSlots = [];
  }
  
  renderListOff();
  
  // 時間指定セクションの表示/非表示
  document.getElementById('show_time_input_off').addEventListener('click', function() {
    const section = document.getElementById('time_input_section_off');
    section.style.display = section.style.display === 'none' ? 'block' : 'none';
  });
  
  // 全休として追加（お休み版）
  document.getElementById('add_all_day_off').addEventListener('click', function() {
    const dateInput = document.getElementById('select_date_off');
    if (!dateInput.value) {
      alert('日付を選択してください');
      return;
    }
    
    // Ajaxで即座に保存
    fetch('/admin_area/settings/add_slot_off', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({
        date: dateInput.value,
        slot_type: 'all_day'
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        disabledOffSlots = data.slots;
        renderListOff();
        dateInput.value = '';
        showSuccessMessageOff();
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('保存に失敗しました');
    });
  });
  
  // 時間指定で追加（お休み版）
  document.getElementById('add_time_range_off').addEventListener('click', function() {
    const dateInput = document.getElementById('select_date_off');
    const startTime = document.getElementById('start_time_off').value;
    const endTime = document.getElementById('end_time_off').value;
    
    if (!dateInput.value) {
      alert('日付を選択してください');
      return;
    }
    
    if (!startTime || !endTime) {
      alert('開始時間と終了時間を入力してください');
      return;
    }
    
    if (startTime >= endTime) {
      alert('終了時間は開始時間より後にしてください');
      return;
    }
    
    // Ajaxで即座に保存
    fetch('/admin_area/settings/add_slot_off', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({
        date: dateInput.value,
        slot_type: 'time_range',
        start_time: startTime,
        end_time: endTime
      })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        disabledOffSlots = data.slots;
        renderListOff();
        dateInput.value = '';
        document.getElementById('time_input_section_off').style.display = 'none';
        showSuccessMessageOff();
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('保存に失敗しました');
    });
  });
  
  function showSuccessMessageOff() {
    const msg = document.getElementById('success_message_off');
    msg.style.display = 'block';
    setTimeout(function() {
      msg.style.display = 'none';
    }, 3000);
  }
  
  function renderListOff() {
    const listContainer = document.getElementById('disabled_items_list_off');
    
    if (disabledOffSlots.length === 0) {
      listContainer.innerHTML = '<p class="text-muted">登録されている不可能日時はありません</p>';
      updateHiddenFieldOff();
      return;
    }
    
    // 日付順にソート
    disabledOffSlots.sort((a, b) => {
      if (a.date !== b.date) return a.date.localeCompare(b.date);
      if (a.type === 'all_day') return -1;
      if (b.type === 'all_day') return 1;
      return (a.start_time || '').localeCompare(b.start_time || '');
    });
    
    let html = '<div style="max-height: 400px; overflow-y: auto;">';
    html += '<table class="table table-striped" style="font-size: 14px;">';
    html += '<thead><tr><th>日付</th><th>制限内容</th><th>操作</th></tr></thead>';
    html += '<tbody>';
    
    disabledOffSlots.forEach((slot, index) => {
      html += '<tr>';
      html += `<td>${slot.date}</td>`;
      
      if (slot.type === 'all_day') {
        html += '<td><span class="badge bg-danger">全休</span></td>';
      } else {
        html += `<td><span class="badge bg-warning text-dark">${slot.start_time} ～ ${slot.end_time}</span></td>`;
      }
      
      html += `<td><button type="button" class="btn btn-sm btn-danger delete-btn-off" data-index="${index}" data-date="${slot.date}" data-type="${slot.type}" data-start-time="${slot.start_time || ''}" data-end-time="${slot.end_time || ''}">削除</button></td>`;
      html += '</tr>';
    });
    
    html += '</tbody></table></div>';
    listContainer.innerHTML = html;
    
    // 削除ボタンのイベント設定
    document.querySelectorAll('.delete-btn-off').forEach(btn => {
      btn.addEventListener('click', function() {
        const index = parseInt(this.getAttribute('data-index'));
        const date = this.getAttribute('data-date');
        const type = this.getAttribute('data-type');
        const startTime = this.getAttribute('data-start-time');
        const endTime = this.getAttribute('data-end-time');
        if (confirm('この設定を削除しますか？')) {
          // Ajaxで削除
          fetch('/admin_area/settings/delete_slot_off', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
            },
            body: JSON.stringify({
              index: index,
              date: date,
              type: type,
              start_time: startTime,
              end_time: endTime
            })
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              disabledOffSlots = data.slots;
              renderListOff();
            }
          })
          .catch(error => {
            console.error('Error:', error);
            alert('削除に失敗しました');
          });
        }
      });
    });
    
    updateHiddenFieldOff();
  }
  
  function updateHiddenFieldOff() {
    // 不要になったが互換性のため残す
  }
});
</script>
