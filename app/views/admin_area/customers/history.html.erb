<div class="container">
  <h2>お休みと振替履歴</h2>

  <% if @customer.blank? %>
    <div class="alert alert-danger">会員情報が取得できませんでした。</div>
    <%= link_to "戻る", admin_area_customers_path, class: "btn btn-secondary" %>
  <% else %>

    <!-- お休み履歴 -->
    <h3>お休み履歴</h3>
    <p>お休みした回数: <%= @offs&.count || 0 %>回</p>

    <table class="table">
    <thead>
      <tr>
        <th>お休み日</th>
        <th>クラス</th>
        <th>契約時間</th>
        <th>契約曜日</th>
        <th>理由</th>
      </tr>
    </thead>

    <tbody>
       <% if @offs.present? %>
         <% @offs.each do |off| %>
           <tr>
             <td><%= off.off_month&.strftime("%Y-%m-%d") || 'データなし' %></td>
             <td><%= off.child&.level || 'データなし' %></td>
             <td><%= [off.child&.contact_time1, off.child&.contact_time2].compact.join(" / ") || 'データなし' %></td>
             <td><%= [off.child&.contact_dey1, off.child&.contact_dey2].compact.join(" / ") || 'データなし' %></td>
             <td><%= off.reason.presence || "未記入" %></td>
           </tr>
         <% end %>
       <% else %>
         <tr><td colspan="5" class="text-center text-muted">お休み履歴はありません</td></tr>
       <% end %>
     </tbody>
   </table>


    <!-- 振替履歴 -->
    <h3 class="mt-5">振替履歴</h3>
    <p>振替登録数: <%= @transfers&.count || 0 %>件</p>
    <div style="overflow-x: auto;">
      <table class="table table-sm">
        <thead>
          <tr>
            <th>子供名</th>
            <th>振替日</th>
            <th>お休み日</th>
            <th>振替時間</th>
            <th>クラス</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% if @transfers.present? %>
            <% @transfers.each do |transfer| %>
              <tr>
                <td><%= transfer.child&.last_name %><%= transfer.child&.first_name %></td>
                <td><%= transfer.transfer_date&.strftime("%Y-%m-%d") || 'データなし' %></td>
                <td><%= transfer.off&.off_month&.strftime("%Y-%m-%d") || 'データなし' %></td>
                <td><%= transfer.transfer_time || 'データなし' %></td>
                <td><%= transfer.level || 'データなし' %></td>
                <td>
                  <%= button_to "削除", 
                      destroy_transfer_admin_area_customer_path(@customer, id: transfer.id), 
                      method: :delete, 
                      data: { confirm: "この振替申込みを削除しますか？" }, 
                      class: "btn btn-sm btn-danger" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr><td colspan="6" class="text-center text-muted">振替履歴はありません</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-4">
      <%= link_to "戻る", admin_area_customer_path(@customer), class: "btn btn-secondary" %>
    </div>

  <% end %>
</div>
